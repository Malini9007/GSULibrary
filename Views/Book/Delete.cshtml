@model GSULibrary.Models.GSUBook

@{
    ViewData["Title"] = "Delete Book";
}

<h1 class="mb-3">Delete Book</h1>

<p class="fs-5">
    Are you sure you want to delete this book?
</p>

<div class="row mt-4">

    <div class="col-sm-2 fw-bold">
        Name
    </div>
    <div class="col-sm-10">
        @Model.Name
    </div>

    <div class="col-sm-2 fw-bold mt-3">
        Author
    </div>
    <div class="col-sm-10 mt-3">
        @Model.Author
    </div>

    <div class="col-sm-2 fw-bold mt-3">
        ISBN
    </div>
    <div class="col-sm-10 mt-3">
        @Model.ISBN
    </div>

    <div class="col-sm-2 fw-bold mt-3">
        Price
    </div>
    <div class="col-sm-10 mt-3">
        @Model.Price.ToString("C")
    </div>

    <div class="col-sm-2 fw-bold mt-3">
        Copies
    </div>
    <div class="col-sm-10 mt-3">
        @Model.NumberOfCopy
    </div>

</div>

<form asp-action="Delete" method="post" class="mt-5">
    <input type="hidden" asp-for="GSUBookId" />

    <button type="submit" class="btn btn-danger">
        Yes, Delete
    </button>

    <a asp-controller="Home"
       asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>
</form>